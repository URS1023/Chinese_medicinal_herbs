/* login.wxss */
.container {
  margin-top: 100rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 60rpx;
}
.form {
  width: 100%;
  padding-top: 100rpx;
}
input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #dddddd;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  padding: 0 20rpx;
}
.form button {
  width: 100%;
  height: 100rpx;
  line-height: 80rpx;
  background-color: #1aad19;
  color: #ffffff;
  border-radius: 10rpx;
  margin-top: 40rpx;
}

.actions {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
}
.actions text {
  color: #576b95;
  font-size: 28rpx;
}
.actions{
  width: 100%;
  justify-content:unset
}
.register{
  margin: 10rpx 0;
  color: #575757;
  margin-left: 10%;
}
.onForgotPassword{
  margin: 10rpx 0;
  color: #575757;
  margin-left: 50%;
}
page {
  background: -webkit-linear-gradient(top,white,#c55e5f);
}
