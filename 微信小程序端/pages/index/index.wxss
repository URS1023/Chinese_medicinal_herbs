/* index.wxss */
.container {
  padding: 20rpx;
}
.search-bar {
  width: 100%;
  padding: 10rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}
.search-bar icon {
  margin-right: 10rpx;
}
.search-bar input {
  width: 100%;
  height: 60rpx;
  padding: 0 20rpx;
}
swiper {
  width: 100%;
  height: 600rpx;
}
swiper image {
  width: 100%;
  height: 100%;
}
.banner-text {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  font-size: 32rpx;
  text-align: center;
}
.category-nav {
  padding-top: 100rpx;
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  margin-top: 20rpx;
}
.category-item {
  width: 25%;
  height: 120rpx;
  line-height: 50rpx;
  text-align: center;
  background-color: #e0e0e0;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}
.category-item-hover {
  background-color: #d0d0d0;
  transform: scale(0.95);
}
.category-item icon {
  margin-bottom: 10rpx;
}
.category-item text {
  font-size: 28rpx;
}
.announcement-section {
  margin-top: 40rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}
.announcement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #eee;
}
.announcement-item:last-child {
  border-bottom: none;
}
.announcement-title {
  flex: 1;
  font-size: 30rpx;
  color: #555;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-right: 20rpx;
}
.announcement-date {
  font-size: 26rpx;
  color: #999;
}