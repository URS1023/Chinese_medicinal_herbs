/* pages/announcement-detail/announcement-detail.wxss */
.container {
  padding: 30rpx;
  background-color: #f8f8f8;
  /* min-height: 100vh; */
}
.announcement-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 20rpx;
}
.announcement-meta {
  width: 100%;
  height: 10%;
  text-align: center;
  margin-bottom: 40rpx;
}
.announcement-date {
  width: 100%;
  height: 10%;
  font-size: 28rpx;
  color: #999;
}
.announcement-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: #666;
  text-align: justify;
} 