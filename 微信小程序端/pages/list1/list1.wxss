/* pages/list1/list1.wxss */
/* 全局样式 */
page {
  background-color: #f8f9fc;
  font-family: system-ui, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 标题样式 */
.page-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #224abe;
  text-align: center;
  margin: 30rpx 0;
}

/* 过滤栏样式 */
.filter-bar {
  background: white;
  border-radius: 15rpx;
  padding: 15rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.filter-btn {
  display: inline-block;
  padding: 10rpx 20rpx;
  margin: 0 10rpx;
  border-radius: 20rpx;
  color: #4e73df;
  border: 2rpx solid #4e73df;
  transition: all 0.3s ease;
}

.filter-btn.active {
  background: linear-gradient(135deg, #4e73df, #224abe);
  color: white;
  border-color: transparent;
}

/* 药材卡片样式 */
.herb-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.herb-card {
  background: white;
  border-radius: 15rpx;
  box-shadow: 0 5px 15px rgba(0,0,0,0.05);
  transition: transform 0.2s;
}

.herb-card:hover, .herb-card:active {
  transform: translateY(-5rpx);
  box-shadow: 0 8px 25px rgba(0,0,0,0.1);
}

.herb-image {
  width: 100%;
  height: 300rpx;
  border-top-left-radius: 15rpx;
  border-top-right-radius: 15rpx;
}

.card-body {
  padding: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 10rpx;
}

.properties {
  margin: 15rpx 0;
}

.properties-tag {
  display: inline-block;
  padding: 3rpx 12rpx;
  margin: 2rpx 5rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  font-size: 24rpx;
  color: #666;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  margin-bottom: 15rpx;
}

.detail-btn {
  width: 100%;
  padding: 10rpx 0;
  background: linear-gradient(135deg, #4e73df, #224abe);
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
  transition: transform 0.2s;
}

.detail-btn:active {
  transform: scale(0.95);
}

/* 分页导航样式 */
.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 30rpx 0;
}

.page-btn {
  display: inline-block;
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  margin: 0 10rpx;
  border-radius: 50%;
  color: #4e73df;
  font-size: 26rpx;
  transition: all 0.3s ease;
}

.page-btn.active {
  background: linear-gradient(135deg, #4e73df, #224abe);
  color: white;
}

/* 模态框样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background: white;
  width: 90%;
  max-width: 750rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #224abe;
}

.close-btn {
  padding-left: 500rpx;
  color: #666;
  background-color: #ffffff;
  cursor: pointer;
}

.detail-row {
  display: flex;
  margin-bottom: 30rpx;
}

.detail-image {
  width: 300rpx;
  height: 300rpx;
  border-radius: 15rpx;
  margin-right: 20rpx;
}

.detail-info {
  flex: 1;
}

.info-item {
  margin-bottom: 15rpx;
  font-size: 26rpx;
  color: #333;
}

.label {
  font-weight: 500;
  color: #666;
  margin-right: 10rpx;
}

.value {
  color: #333;
}

.detail-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #224abe;
  margin-bottom: 15rpx;
}

.desc {
  font-size: 24rpx;
  line-height: 1.6;
  color: #666;
}

.similar-herbs {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.similar-herb-tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 25rpx;
  background: linear-gradient(135deg, #4e73df, #224abe);
  color: white;
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.no-record {
  color: #999;
  font-size: 24rpx;
}


.banner{
  width: 100%;
  height: 350rpx;
}
.banner swiper{
  height: 100%;
  width: 100%;
}
.banner image{
  width: 100%;
  height: 350rpx;
}

